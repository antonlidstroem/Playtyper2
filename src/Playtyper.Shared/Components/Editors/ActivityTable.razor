@* Aktiviteter-fliken. Activity.cs har ~40 fält totalt (quiz, actions,
   contentBlocks, audio, schemaläggning m.m.) - den här vyn täcker de
   fält som faktiskt redigeras oftast. Resten rör sig oskadat genom
   JSON-serialiseringen och nås vid behov via Avancerat-fliken. *@

<div class="editor-pane editor-pane--wide">
    <p class="help-text">@HelpText.Tabs["activities"].Summary</p>

    <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;flex-wrap:wrap">
        <h3 style="margin:0">Aktiviteter</h3>
        <select @bind="_lang" style="width:auto">
            @foreach (var lang in Draft.ActivitiesByLang.Keys)
            {
                <option value="@lang">@lang</option>
            }
        </select>
        <span style="color:var(--color-text-muted);font-size:13px">@CurrentList.Count st</span>
        <button class="primary" style="margin-left:auto" @onclick="AddActivity">+ Ny aktivitet</button>
    </div>

    <div class="activity-list">
        @foreach (var activity in CurrentList)
        {
            <div class="activity-row @(activity == _selected ? "activity-row--active" : "")" @onclick="() => Select(activity)" @onkeydown='e => { if (e.Key is "Enter" or " ") Select(activity); }' role="button" tabindex="0">
                <span style="font-size:18px">@activity.Emoji</span>
                <span style="flex:1;text-align:left;min-width:0">
                    <strong style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@(string.IsNullOrWhiteSpace(activity.Title) ? "(namnlös)" : activity.Title)</strong>
                    <span style="font-size:12px;color:var(--color-text-muted)">@activity.Category · @activity.Id</span>
                </span>
                <button class="ghost" style="padding:4px 8px" @onclick="() => Delete(activity)" @onclick:stopPropagation="true" title="Ta bort">✕</button>
            </div>
        }
    </div>

    <h3 style="margin-top:28px">Moduler <span style="font-size:12px;font-weight:400;color:var(--color-text-muted)">@Draft.Config.Modules.Count</span></h3>
    <p class="help-text help-text--tight">
        Grupperar aktiviteter i en bestämd ordning som besökaren låser upp steg för steg — till exempel en kurs där man måste klara steg 1 innan steg 2 öppnas.
        <details class="info-note">
            <summary>?</summary>
            <span class="info-note__body">För att modulerna faktiskt ska VISAS som låsta i appen (inte bara ordnade) måste du även slå på "Moduler med låsta aktiviteter i ordning" under Innehåll-fliken. Utan den är aktiviteterna grupperade men olåsta — besökaren kan öppna dem i valfri ordning.</span>
        </details>
    </p>
    <div class="module-list">
        @foreach (var module in Draft.Config.Modules)
        {
            <div class="card module-item">
                <div class="field-grid">
                    <div>
                        <label>Emoji</label>
                        <input @bind="module.Emoji" @bind:event="oninput" @bind:after="Notify" style="width:60px;text-align:center" />
                    </div>
                    <div>
                        <label>Id</label>
                        <input @bind="module.Id" @bind:event="oninput" @bind:after="Notify" />
                    </div>
                    <div style="grid-column:1/-1">
                        <label>Rubrik</label>
                        <input @bind="module.TitleKey" @bind:event="oninput" @bind:after="Notify" />
                    </div>
                    <div style="grid-column:1/-1">
                        <label>Låses upp efter</label>
                        <select @bind="module.UnlockAfter" @bind:after="Notify">
                            <option value="none">Ingen — den här modulen är alltid olåst</option>
                            @foreach (var other in Draft.Config.Modules.Where(m => m != module))
                            {
                                <option value="@other.Id">@other.TitleKey (@other.Id)</option>
                            }
                        </select>
                    </div>
                </div>
                <label style="display:block;margin-top:8px;font-size:12px;color:var(--color-text-muted)">
                    Aktiviteter i modulen (ordning spelar roll) · @CurrentLangLabel
                </label>
                <div class="module-item__activities">
                    @foreach (var activity in CurrentList)
                    {
                        <label class="module-activity-check">
                            <input type="checkbox" checked="@module.ActivityIds.Contains(activity.Id)" @onchange="e => ToggleModuleActivity(module, activity.Id, e.Value is bool b && b)" />
                            @activity.Emoji @(string.IsNullOrWhiteSpace(activity.Title) ? activity.Id : activity.Title)
                        </label>
                    }
                </div>
                <button class="ghost stack-item__remove" @onclick="() => { Draft.Config.Modules.Remove(module); Notify(); }">Ta bort modul</button>
            </div>
        }
    </div>
    <button class="ghost" @onclick="AddModule">+ Modul</button>
</div>

<style>
    .module-list { display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
    .module-item { padding: 12px; }
    .module-item__activities { display: flex; flex-direction: column; gap: 4px; margin-top: 6px; max-height: 180px; overflow-y: auto; padding: 6px; border: 1px solid var(--color-border); border-radius: 6px; }
    .module-activity-check { display: flex; align-items: center; gap: 8px; font-size: 13px; }
    .stack-item__remove { margin-top: 10px; font-size: 12px; padding: 4px 10px; color: var(--color-danger-text); }
</style>

@if (_selected != null)
{
    <div class="modal-backdrop" @onclick="() => _selected = null">
        <div class="modal card" style="max-width:560px" @onclick:stopPropagation="true">
            <h3>Redigera aktivitet</h3>
            <div class="field-grid">
                <div><label>Id</label><input @bind="_selected.Id" @bind:event="oninput" @bind:after="Notify" /></div>
                <div><label>Emoji</label><input @bind="_selected.Emoji" @bind:event="oninput" @bind:after="Notify" style="max-width:80px" /></div>
                <div style="grid-column:1/-1"><label>Titel</label><input @bind="_selected.Title" @bind:event="oninput" @bind:after="Notify" /></div>
                <div style="grid-column:1/-1"><label>Beskrivning</label><textarea rows="2" @bind="_selected.Description" @bind:event="oninput" @bind:after="Notify"></textarea></div>
                <div><label>Kategori</label><input @bind="_selected.Category" @bind:event="oninput" @bind:after="Notify" /></div>
                <div><label>Nivå (1-3)</label><input type="number" min="0" max="3" @bind="_selected.Level" @bind:event="oninput" @bind:after="Notify" /></div>
                <div><label>Förberedelsetid (min)</label><input type="number" @bind="_selected.PrepTimeMinutes" @bind:event="oninput" @bind:after="Notify" /></div>
                <div><label>Kräver rekvisita <span style="color:var(--color-text-muted)">(saker/material besökaren behöver ha till hands)</span></label>
                    <select @bind="_selected.RequiresProps" @bind:after="Notify">
                        <option value="false">Nej</option>
                        <option value="true">Ja</option>
                    </select>
                </div>
                <div style="grid-column:1/-1">
                    <label>Steg <span style="color:var(--color-text-muted)">(en rad per steg — visas som en numrerad lista för besökaren)</span></label>
                    <textarea rows="4" value="@string.Join("\n", _selected.Steps)" @onchange="e => SetSteps(e.Value?.ToString())"></textarea>
                </div>
                <div style="grid-column:1/-1">
                    <label>Taggar <span style="color:var(--color-text-muted)">(kommaseparerat)</span></label>
                    <input value="@string.Join(", ", _selected.Tags)" @onchange="e => SetTags(e.Value?.ToString())" />
                </div>
                <div style="grid-column:1/-1">
                    <label>Säkerhetsnotis <span style="color:var(--color-text-muted)">(valfritt)</span></label>
                    <input value="@_selected.SafetyNote" @onchange="e => { _selected.SafetyNote = e.Value?.ToString(); Notify(); }" />
                </div>
            </div>
            <p style="font-size:12px;color:var(--color-text-muted);margin-top:10px">
                Quiz, actions, ljud och schemaläggning redigeras i Avancerat-fliken tills vidare.
            </p>
            <div style="display:flex;justify-content:flex-end;margin-top:12px">
                <button class="primary" @onclick="() => _selected = null">Klar</button>
            </div>
        </div>
    </div>
}

<style>
    @* editor-pane/field-grid saknades här (fanns bara i IdentityEditor.razor
       m.fl:s egna <style>-block, och en inline <style>-tagg försvinner ur
       DOM:en så fort komponenten som skrev den avmonteras) — så fort man
       gick direkt till Aktiviteter-fliken utan att först ha besökt en
       flik som råkade definiera dem miste både den befintliga
       redigera-aktivitet-modalen och den nya Moduler-sektionen nedan sin
       rutnätslayout. Samma värden som i övriga editorer, inte en ny stil. *@
    .editor-pane { padding: 20px 24px 60px; max-width: 720px; }
    .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px; margin-top: 10px; }
    .editor-pane--wide { max-width: 820px; }
    .activity-list { display: flex; flex-direction: column; gap: 6px; margin-top: 12px; }
    .activity-row { display: flex; align-items: center; gap: 10px; padding: 10px 12px; text-align: left; background: var(--color-surface-1); border: 1px solid var(--color-border); border-radius: var(--radius-sm); cursor: pointer; }
    .activity-row:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 1px; }
    .activity-row--active { border-color: var(--color-accent); }
    @@media (max-width: 560px) { .field-grid { grid-template-columns: 1fr; } }
</style>

@code {
    [Parameter, EditorRequired] public PackDraft Draft { get; set; } = default!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private string _lang = "";
    private Activity? _selected;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_lang) || !Draft.ActivitiesByLang.ContainsKey(_lang))
            _lang = Draft.ActivitiesByLang.Keys.FirstOrDefault() ?? "sv";
    }

    private List<Activity> CurrentList =>
        Draft.ActivitiesByLang.TryGetValue(_lang, out var list) ? list : (Draft.ActivitiesByLang[_lang] = new());

    private void Select(Activity a) => _selected = a;

    private void AddActivity()
    {
        var newActivity = new Activity { Id = $"activity-{CurrentList.Count + 1}", Title = "Ny aktivitet" };
        CurrentList.Add(newActivity);
        _selected = newActivity;
        Notify();
    }

    private void Delete(Activity a)
    {
        CurrentList.Remove(a);
        if (_selected == a) _selected = null;
        Notify();
    }

    private string CurrentLangLabel => _lang;

    private void AddModule()
    {
        Draft.Config.Modules.Add(new ProgressionModule { Id = $"module-{Draft.Config.Modules.Count + 1}" });
        Notify();
    }

    private void ToggleModuleActivity(ProgressionModule module, string activityId, bool on)
    {
        if (on && !module.ActivityIds.Contains(activityId)) module.ActivityIds.Add(activityId);
        else if (!on) module.ActivityIds.Remove(activityId);
        Notify();
    }

    private void SetSteps(string? raw)
    {
        if (_selected == null) return;
        _selected.Steps = (raw ?? "").Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        Notify();
    }

    private void SetTags(string? raw)
    {
        if (_selected == null) return;
        _selected.Tags = (raw ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        Notify();
    }

    private async Task Notify() => await OnChanged.InvokeAsync();
}
