@* Identitet-fliken. Muterar Draft.Config direkt (referenstyp) - OnChanged
   triggar bara omritning + IndexedDB-persistering i föräldern. *@

<div class="editor-pane">
    <h3>Identitet</h3>
    <p class="help-text">@HelpText.Tabs["identity"].Summary Det här gäller <strong>@Draft.PackId</strong>.</p>

    <div class="field-grid">
        <div>
            <label>App-namn</label>
            <input @bind="Draft.Config.AppName" @bind:event="oninput" @bind:after="Notify" />
        </div>
        <div>
            <label>Emoji</label>
            <input @bind="Draft.Config.Emoji" @bind:event="oninput" @bind:after="Notify" style="max-width:80px" />
        </div>
        <div style="grid-column:1/-1">
            <label>Tagline <span class="field-hint">(en kort undertext, visas ofta nära namnet)</span></label>
            <input @bind="Draft.Config.Tagline" @bind:event="oninput" @bind:after="Notify" />
        </div>
        <div>
            <label>Version</label>
            <input @bind="Draft.Config.Version" @bind:event="oninput" @bind:after="Notify" />
        </div>
        <div>
            <label>Standardspråk</label>
            <input @bind="Draft.Config.DefaultLanguage" @bind:event="oninput" @bind:after="Notify" style="max-width:100px" />
        </div>
    </div>

    <h3 style="margin-top:24px">Panic-knapp <span class="tab-badge">valfritt</span></h3>
    <p class="help-text">
        En alltid-synlig genvägsknapp för akuta situationer — trycker besökaren på den hoppar appen direkt till en förenklad vy, utan att behöva leta.
        <details class="info-note">
            <summary>?</summary>
            <span class="info-note__body">Tänkt för appar där besökaren kan behöva snabb hjälp mitt i en stressad stund — knappen finns kvar synlig oavsett var i appen man är, och tar en direkt till det viktigaste. Helt valfritt: lämna den bara med sitt förvalda utseende om appen inte behöver den här typen av genväg.</span>
        </details>
    </p>
    <div class="field-grid">
        <div>
            <label>
                Etikett <span class="field-hint">(texten på knappen)</span>
                <details class="info-note">
                    <summary>?</summary>
                    <span class="info-note__body">@HelpText.TranslationKeyExplanation</span>
                </details>
            </label>
            <input @bind="Draft.Config.PanicButton.LabelKey" @bind:event="oninput" @bind:after="Notify" />
        </div>
        <div>
            <label>Stil</label>
            <select @bind="Draft.Config.PanicButton.Style" @bind:after="Notify">
                <option value="calm">Lugn — mjuk, diskret färg</option>
                <option value="urgent">Uppmärksamhetsväckande — stark, tydlig färg</option>
            </select>
        </div>
    </div>

    <h3 style="margin-top:24px">Språk</h3>
    <p class="help-text">
        De språk som visas i appens språkväljare, utöver Standardspråk ovan. Du behöver bara lägga till en rad här om du vill att besökaren ska kunna VÄLJA det språket manuellt — appen upptäcker automatiskt vilka översättningar som faktiskt finns, så listan behöver inte vara fullständig.
    </p>
    <div class="chip-list">
        @foreach (var lang in Draft.Config.Languages)
        {
            <div class="card chip-edit">
                <input value="@lang.Flag" @onchange="e => { lang.Flag = e.Value?.ToString() ?? lang.Flag; Notify(); }" placeholder="🇸🇪" style="width:44px;text-align:center" />
                <input value="@lang.Code" @onchange="e => { lang.Code = e.Value?.ToString() ?? lang.Code; Notify(); }" placeholder="sv" style="width:70px" />
                <input value="@lang.Label" @onchange="e => { lang.Label = e.Value?.ToString() ?? lang.Label; Notify(); }" placeholder="Svenska" style="flex:1" />
                <button class="ghost" @onclick="() => { Draft.Config.Languages.Remove(lang); Notify(); }">✕</button>
            </div>
        }
    </div>
    <button class="ghost" @onclick="AddLanguage">+ Språk</button>

    <h3 style="margin-top:24px">Startvy &amp; egen CSS</h3>
    <div class="field-grid">
        <div style="grid-column:1/-1">
            <label>Vad besökaren ser först när appen öppnas</label>
            <select @bind="Draft.Config.StartView" @bind:after="Notify">
                @foreach (var option in HelpText.StartViewOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
            <p class="help-text help-text--tight">
                @(HelpText.StartViewOptions.FirstOrDefault(o => o.Value == Draft.Config.StartView)?.Description ?? "Bestämmer vilken skärm besökaren möter direkt när appen öppnas.")
            </p>
        </div>
        <div style="grid-column:1/-1">
            <label>
                Egen CSS <span class="tab-badge tab-badge--muted">för den tekniskt kunniga</span>
            </label>
            <p class="help-text help-text--tight">
                Valfritt. Om du kan CSS kan du klistra in egen kod här för finjusteringar utöver det de andra flikarna erbjuder. Läggs till sist, vilket betyder att den kan skriva över färgvalen du gjort på Utseende-fliken — lämna tomt om du är osäker.
            </p>
            <textarea rows="5" style="font-family:monospace;font-size:12px" value="@Draft.Config.CustomCss" @onchange="e => { Draft.Config.CustomCss = e.Value?.ToString(); Notify(); }"></textarea>
        </div>
    </div>
</div>

<style>
    .editor-pane { padding: 20px 24px 60px; max-width: 720px; }
    .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px; margin-top: 10px; }
    .chip-list { display: flex; flex-direction: column; gap: 6px; margin-top: 8px; }
    .chip-edit { display: flex; gap: 8px; align-items: center; padding: 8px; }
    @@media (max-width: 520px) { .field-grid { grid-template-columns: 1fr; } }
</style>

@code {
    [Parameter, EditorRequired] public PackDraft Draft { get; set; } = default!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private void AddLanguage()
    {
        Draft.Config.Languages.Add(new LanguageOption { Code = "sv", Label = "Svenska", Flag = "🇸🇪" });
        _ = Notify();
    }

    private async Task Notify() => await OnChanged.InvokeAsync();
}
