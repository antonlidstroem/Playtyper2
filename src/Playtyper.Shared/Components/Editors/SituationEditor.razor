@* Läge & genvägar: SituationPresets, QuickActions, ReadyNow, Mascot.
   GAPS.md §4 prioriterade SituationPresets/QuickActions högst av de 16
   fält som bara gick att nå via rå JSON — det är alla fyra av dem här. *@

<div class="editor-pane editor-pane--wide">

    <h3>Maskot</h3>
    <p class="section-hint">Visas i tomma tillstånd och vissa laddningslägen.</p>
    <div class="field-grid">
        <div>
            <label>Emoji</label>
            <input @bind="Draft.Config.Mascot.Emoji" @bind:event="oninput" @bind:after="Notify" style="width:70px;text-align:center" />
        </div>
        <div>
            <label>Animation</label>
            <input @bind="Draft.Config.Mascot.Animation" @bind:event="oninput" @bind:after="Notify" placeholder="wobble" />
            <span class="field-note">Fri text — vilka värden UI:t faktiskt animerar avgörs av mascot.css, inte listat här.</span>
        </div>
    </div>

    <h3 style="margin-top:28px">Redo nu</h3>
    <label class="toggle-row">
        <input type="checkbox" checked="@(Draft.Config.ReadyNow != null)" @onchange="ToggleReadyNow" />
        Visa en "redo nu"-sektion (kort urval aktiviteter som matchar Criteria just nu)
    </label>
    @if (Draft.Config.ReadyNow is { } rn)
    {
        <div class="field-grid" style="margin-top:8px">
            <div>
                <label>Etikett</label>
                <input @bind="rn.LabelKey" @bind:event="oninput" @bind:after="Notify" />
            </div>
            <div>
                <label>Underetikett</label>
                <input @bind="rn.SublabelKey" @bind:event="oninput" @bind:after="Notify" />
            </div>
            <div>
                <label>Antal</label>
                <input type="number" min="1" max="20" @bind="rn.Count" @bind:after="Notify" style="width:80px" />
            </div>
        </div>
        <label class="field-note" style="display:block;margin-top:10px">Kriterier (matchas mot aktiviteternas egna filter-taggar)</label>
        <DictEditor Dict="rn.Criteria" OnChanged="Notify" AddLabel="Kriterium" />
    }

    <h3 style="margin-top:28px">Situationsknappar <span class="count-badge">@Draft.Config.SituationPresets.Count</span></h3>
    <p class="section-hint">Ett tryck applicerar FilterBundle på det aktiva filtret och visar det vanliga flödet.</p>
    <div class="stack-list">
        @foreach (var preset in Draft.Config.SituationPresets)
        {
            <div class="card stack-item">
                <div class="field-grid">
                    <div>
                        <label>Emoji</label>
                        <input @bind="preset.Emoji" @bind:event="oninput" @bind:after="Notify" style="width:60px;text-align:center" />
                    </div>
                    <div>
                        <label>Id</label>
                        <input @bind="preset.Id" @bind:event="oninput" @bind:after="Notify" />
                    </div>
                    <div style="grid-column:1/-1">
                        <label>Etikett</label>
                        <input @bind="preset.LabelKey" @bind:event="oninput" @bind:after="Notify" />
                    </div>
                </div>
                <label class="field-note" style="display:block;margin-top:8px">Filter som appliceras</label>
                <DictEditor Dict="preset.FilterBundle" OnChanged="Notify" AddLabel="Filter" />
                <button class="ghost stack-item__remove" @onclick="() => { Draft.Config.SituationPresets.Remove(preset); Notify(); }">Ta bort</button>
            </div>
        }
    </div>
    <button class="ghost" @onclick="AddSituationPreset">+ Situationsknapp</button>

    <h3 style="margin-top:28px">Snabbåtgärder <span class="count-badge">@Draft.Config.QuickActions.Count</span></h3>
    <p class="section-hint">Bredare än situationsknappar — kan även hoppa rakt till en aktivitet eller kategori, inte bara filtrera.</p>
    <div class="stack-list">
        @foreach (var qa in Draft.Config.QuickActions)
        {
            <div class="card stack-item">
                <div class="field-grid">
                    <div>
                        <label>Emoji</label>
                        <input @bind="qa.Emoji" @bind:event="oninput" @bind:after="Notify" style="width:60px;text-align:center" />
                    </div>
                    <div>
                        <label>Id</label>
                        <input @bind="qa.Id" @bind:event="oninput" @bind:after="Notify" />
                    </div>
                    <div style="grid-column:1/-1">
                        <label>Etikett</label>
                        <input @bind="qa.LabelKey" @bind:event="oninput" @bind:after="Notify" />
                    </div>
                    <div>
                        <label>Stil</label>
                        <select @bind="qa.Style" @bind:after="Notify">
                            <option value="calm">calm</option>
                            <option value="urgent">urgent</option>
                        </select>
                    </div>
                    <div>
                        <label>Beteende</label>
                        <select @bind="qa.Behavior" @bind:after="Notify">
                            <option value="randomFromPool">Slumpa från urval</option>
                            <option value="applyFilter">Applicera filter</option>
                            <option value="openActivity">Öppna aktivitet</option>
                            <option value="openCategory">Öppna kategori</option>
                        </select>
                    </div>
                </div>

                @if (qa.Behavior is "randomFromPool" or "applyFilter")
                {
                    <label class="field-note" style="display:block;margin-top:8px">Filter som styr urvalet</label>
                    <DictEditor Dict="qa.FilterBundle" OnChanged="Notify" AddLabel="Filter" />
                }
                else if (qa.Behavior == "openActivity")
                {
                    <div style="margin-top:8px">
                        <label>Aktivitets-id</label>
                        <input value="@qa.TargetActivityId" @onchange="e => { qa.TargetActivityId = e.Value?.ToString(); Notify(); }" placeholder="t.ex. samma id som i Aktiviteter-fliken" />
                    </div>
                }
                else if (qa.Behavior == "openCategory")
                {
                    <div style="margin-top:8px">
                        <label>Kategori</label>
                        <select value="@qa.TargetCategoryId" @onchange="e => { qa.TargetCategoryId = e.Value?.ToString(); Notify(); }">
                            <option value="">– välj –</option>
                            @foreach (var cat in Draft.Config.Categories)
                            {
                                <option value="@cat.Id">@cat.Emoji @cat.LabelKey</option>
                            }
                        </select>
                    </div>
                }
                <button class="ghost stack-item__remove" @onclick="() => { Draft.Config.QuickActions.Remove(qa); Notify(); }">Ta bort</button>
            </div>
        }
    </div>
    <button class="ghost" @onclick="AddQuickAction">+ Snabbåtgärd</button>
</div>

<style>
    .editor-pane { padding: 20px 24px 60px; max-width: 720px; }
    .editor-pane--wide { max-width: 860px; }
    .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px; margin-top: 10px; }
    .section-hint { color: var(--color-text-secondary); font-size: 13px; margin: 2px 0 4px; }
    .field-note { color: var(--color-text-muted); font-size: 12px; }
    .count-badge { font-size: 12px; font-weight: 400; color: var(--color-text-muted); }
    .toggle-row { display: flex; align-items: center; gap: 8px; font-size: 14px; margin-top: 6px; }
    .stack-list { display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
    .stack-item { padding: 12px; position: relative; }
    .stack-item__remove { margin-top: 10px; font-size: 12px; padding: 4px 10px; color: var(--color-danger, #c0392b); }
    @@media (max-width: 560px) { .field-grid { grid-template-columns: 1fr; } }
</style>

@code {
    [Parameter, EditorRequired] public PackDraft Draft { get; set; } = default!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private void ToggleReadyNow(ChangeEventArgs e)
    {
        var on = e.Value is bool b && b;
        Draft.Config.ReadyNow = on ? (Draft.Config.ReadyNow ?? new ReadyNowConfig()) : null;
        Notify();
    }

    private void AddSituationPreset()
    {
        Draft.Config.SituationPresets.Add(new SituationPreset { Id = $"preset-{Draft.Config.SituationPresets.Count + 1}", Emoji = "✨" });
        Notify();
    }

    private void AddQuickAction()
    {
        Draft.Config.QuickActions.Add(new QuickActionConfig { Id = $"action-{Draft.Config.QuickActions.Count + 1}" });
        Notify();
    }

    private void Notify() => OnChanged.InvokeAsync();
}
