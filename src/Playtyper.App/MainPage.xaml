<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Playtyper.App"
             x:Class="Playtyper.App.MainPage"
             BackgroundColor="{StaticResource PageBackground}">

    <blazorWebView:BlazorWebView xmlns:blazorWebView="clr-namespace:Microsoft.AspNetCore.Components.WebView.Maui;assembly=Microsoft.AspNetCore.Components.WebView.Maui"
                                  HostPage="wwwroot/index.html">
        <blazorWebView:BlazorWebView.RootComponents>
            <blazorWebView:RootComponent Selector="#app" ComponentType="{x:Type local:MauiAppRoot}" />
        </blazorWebView:BlazorWebView.RootComponents>
    </blazorWebView:BlazorWebView>

</ContentPage>
