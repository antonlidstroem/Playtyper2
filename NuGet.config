<?xml version="1.0" encoding="utf-8"?>
<!--
  Feed for Playtypus.Core (see src/Playtyper.Shared/Playtyper.Shared.csproj
  and the root README's "Konsumera Playtypus.Core" section).

  One-time local setup:
    1. Create a GitHub PAT (classic) with the read:packages scope.
    2. Set it as an environment variable, e.g. in your shell profile:
         export PLAYTYPUS_NUGET_PAT=ghp_xxx
    3. dotnet restore picks it up automatically via the %PLAYTYPUS_NUGET_PAT%
       substitution below — nothing else to configure.

  In CI, deploy-pages.yml sets the same environment variable from the
  PLAYTYPUS_TOKEN secret before restore/build.

  Replace DITT_ORG below with the GitHub org/user that owns the Playtypus
  repo (same value as PLAYTYPUS_TOKEN's target in deploy-pages.yml).

  Restore suddenly failing with 401/403 against nuget.pkg.github.com
  (nuget.org packages still fine)? The PAT above expired — see README's
  "Token gick ut?" right under "Konsumera Playtypus.Core" for the
  renewal steps. Not a code problem, don't go looking for one here.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="playtypus-github" value="https://nuget.pkg.github.com/DITT_ORG/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <playtypus-github>
      <add key="Username" value="DITT_ORG" />
      <add key="ClearTextPassword" value="%PLAYTYPUS_NUGET_PAT%" />
    </playtypus-github>
  </packageSourceCredentials>
</configuration>
